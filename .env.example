DJANGO_SECRET_KEY=change-me-in-production-please
DJANGO_DEBUG=1
# For PythonAnywhere: set to your username.pythonanywhere.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourusername.pythonanywhere.com

# Default admin account (created automatically on deploy)
DEFAULT_ADMIN_USERNAME=Yosef
DEFAULT_ADMIN_EMAIL=yosef@church.et
DEFAULT_ADMIN_PASSWORD=P@ssw0rds
DEFAULT_ADMIN_FULL_NAME_AM=ዮሴፍ

# Database - MySQL for PythonAnywhere
DB_TYPE=mysql
MYSQL_DATABASE=yourusername$plansys
MYSQL_USER=yourusername
MYSQL_PASSWORD=your-mysql-password
MYSQL_HOST=yourusername.mysql.pythonanywhere.com
MYSQL_PORT=3306

# Local file storage path (documents will be stored here)
DOCUMENT_STORAGE_PATH=/home/yourusername/planmanagement/media/documents

JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

CORS_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com

# Document URL lifetime in seconds (default: 604800 = 7 days)
DOCUMENT_URL_EXPIRY=604800

# Email / SMTP — PythonAnywhere provides SMTP, or set custom
EMAIL_NOTIFICATIONS_ENABLED=0
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.pythonanywhere.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=yourusername@pythonanywhere.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=yourusername@pythonanywhere.com