DJANGO_SECRET_KEY=change-me-in-production-please
DJANGO_DEBUG=1
# Production: set to 0 and list your Railway domain, e.g. myapp.up.railway.app
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Default admin account (created automatically on deploy)
DEFAULT_ADMIN_USERNAME=Yosef
DEFAULT_ADMIN_EMAIL=yosef@church.et
DEFAULT_ADMIN_PASSWORD=P@ssw0rds
DEFAULT_ADMIN_FULL_NAME_AM=ዮሴፍ

POSTGRES_DB=plansys
POSTGRES_USER=plansys
POSTGRES_PASSWORD=plansys

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=plansys-docs

JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

CORS_ALLOWED_ORIGINS=http://localhost:4300

# Document presigned URL lifetime in seconds (default: 604800 = 7 days)
DOCUMENT_URL_EXPIRY=604800

# Email / SMTP — set EMAIL_NOTIFICATIONS_ENABLED=1 and configure SMTP to activate
EMAIL_NOTIFICATIONS_ENABLED=0
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=secret
DEFAULT_FROM_EMAIL=no-reply@example.com
